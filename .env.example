# =============================================================================
# RAPTOR RAG Platform — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- Database (PostgreSQL / Cloud SQL) ---
DATABASE_URL=postgresql+asyncpg://raptor:raptor@localhost:5432/raptor
DATABASE_URL_SYNC=postgresql://raptor:raptor@localhost:5432/raptor

# --- Redis (local / Memorystore) ---
REDIS_URL=redis://localhost:6379/0

# --- Vector DB (Qdrant) ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# --- Object Storage ---
# Provider: "s3" for MinIO/S3 (dev), "gcs" for Google Cloud Storage (prod)
STORAGE_PROVIDER=s3

# S3 / MinIO settings (local dev)
S3_ENDPOINT=http://localhost:9000
STORAGE_BUCKET=raptor-documents
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_REGION=us-east-1

# GCS settings (production — set STORAGE_PROVIDER=gcs)
GCS_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=

# Additional buckets
STORAGE_TREE_BUCKET=raptor-trees
STORAGE_MODEL_BUCKET=raptor-models

# --- LLM Providers ---
# Local Ollama (dev)
OLLAMA_BASE_URL=http://localhost:11435

# Cloud LLM providers
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Default LLM settings
LLM_PROVIDER=ollama
LLM_MODEL=mistral:latest
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048

# --- Reranker ---
RERANKER_ENABLED=true
RERANKER_MODEL=BAAI/bge-reranker-base
RERANKER_TOP_K=5

# --- Auth (Clerk) ---
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_WEBHOOK_SECRET=

# --- Monitoring ---
SENTRY_DSN=

# --- App Settings ---
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
DEBUG=true
LOG_LEVEL=INFO
ENVIRONMENT=development

# --- Server ---
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=["http://localhost:3000","http://localhost:7860"]
